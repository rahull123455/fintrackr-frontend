generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  otpCode          String?
  otpExpiresAt     DateTime?
  twoFactorEnabled Boolean    @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  expenses     Expense[]
  savingsGoals SavingsGoal[]
  aiPrediction AiPrediction?
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Decimal  @db.Decimal(10, 2)
  category  String
  spentAt   DateTime
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, spentAt])
}

model ContactInquiry {
  id           String   @id @default(cuid())
  name         String
  surname      String
  organization String
  email        String
  comments     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
  @@index([email])
}

model SavingsGoal {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  targetAmount        Decimal  @db.Decimal(10, 2)
  savedAmount         Decimal  @db.Decimal(10, 2) @default(0)
  monthlyContribution Decimal  @db.Decimal(10, 2) @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiPrediction {
  id         String   @id @default(cuid())
  userId     String   @unique
  month      String
  prediction Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
